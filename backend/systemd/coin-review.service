[Unit]
Description=Weekly Coin Review - AI Analysis
After=network.target

[Service]
Type=oneshot
User=louis
WorkingDirectory=/home/louis/ZenithGrid/backend
ExecStart=/home/louis/ZenithGrid/backend/venv/bin/python scripts/run_coin_review.py
StandardOutput=journal
StandardError=journal

# Environment
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
